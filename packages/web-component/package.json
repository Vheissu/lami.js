{
  "name": "@lami.js/web-component",
  "version": "1.0.0",
  "description": "Web Component adapter for Lami.js element definitions.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vheissu/lami.js.git",
    "directory": "packages/web-component"
  },
  "bugs": {
    "url": "https://github.com/Vheissu/lami.js/issues"
  },
  "homepage": "https://github.com/Vheissu/lami.js/tree/main/packages/web-component#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lami.js/runtime": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  }
}
